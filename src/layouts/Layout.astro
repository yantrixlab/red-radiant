---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'YouTube to MP3 Converter — Free, Fast, No Ads | youtube2mp3file.com',
  description = 'Convert YouTube videos to MP3, WAV, and M4A for free. No ads, no signup required. Up to 320kbps HD quality. Supports playlists and YouTube Shorts.'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Youtube2mp3File" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="youtube to mp3, youtube converter, youtube downloader, yt to mp3, free mp3 converter, youtube to wav, youtube to m4a, youtube playlist downloader, youtube shorts to mp3" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://youtube2mp3file.com" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href="https://youtube2mp3file.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "YouTube to MP3 Converter",
      "url": "https://youtube2mp3file.com",
      "description": "Free YouTube to MP3 converter — no ads, no signup, 320kbps quality",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "All",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "featureList": ["MP3 conversion", "WAV conversion", "M4A conversion", "Playlist support", "320kbps quality", "No registration required"]
    }
    </script>
  </head>
  <body class="bg-canvas-soft text-ink font-sans">
    <slot />
  </body>
</html>
