---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
if (Astro.locals.user) return Astro.redirect('/account');
---

<Layout title="Sign up — youtube2mp3file.com">
  <Nav />
  <main class="min-h-screen flex items-center justify-center px-4 pt-24 pb-12">
    <div class="w-full max-w-sm">
      <div class="text-center mb-8">
        <h1 class="text-2xl font-semibold text-ink">Create an account</h1>
        <p class="text-sm text-muted mt-1">Free forever · No credit card required</p>
      </div>

      <div class="bg-canvas rounded-xl border border-hairline shadow-sm p-6 space-y-4">
        <button id="google-btn" class="w-full flex items-center justify-center gap-3 h-10 px-4 text-sm font-medium text-ink bg-canvas border border-hairline rounded-lg hover:bg-canvas-soft-2 transition-colors">
          <svg width="18" height="18" viewBox="0 0 18 18"><path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.875 2.684-6.615z"/><path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.258c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z"/><path fill="#FBBC05" d="M3.964 10.707A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.707V4.961H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.039l3.007-2.332z"/><path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.961L3.964 6.293C4.672 4.166 6.656 3.58 9 3.58z"/></svg>
          Continue with Google
        </button>

        <div class="flex items-center gap-3">
          <hr class="flex-1 border-hairline" />
          <span class="text-xs text-muted">or</span>
          <hr class="flex-1 border-hairline" />
        </div>

        <form id="signup-form" class="space-y-3">
          <div>
            <label class="block text-xs font-medium text-ink mb-1" for="name">Name</label>
            <input id="name" type="text" required autocomplete="name"
              class="w-full h-10 px-3 text-sm text-ink bg-canvas border border-hairline rounded-lg focus:outline-none focus:border-hairline-strong focus:ring-2 focus:ring-ink/5 transition-all placeholder:text-muted"
              placeholder="Your name" />
          </div>
          <div>
            <label class="block text-xs font-medium text-ink mb-1" for="email">Email</label>
            <input id="email" type="email" required autocomplete="email"
              class="w-full h-10 px-3 text-sm text-ink bg-canvas border border-hairline rounded-lg focus:outline-none focus:border-hairline-strong focus:ring-2 focus:ring-ink/5 transition-all placeholder:text-muted"
              placeholder="you@example.com" />
          </div>
          <div>
            <label class="block text-xs font-medium text-ink mb-1" for="password">Password</label>
            <input id="password" type="password" required autocomplete="new-password" minlength="8"
              class="w-full h-10 px-3 text-sm text-ink bg-canvas border border-hairline rounded-lg focus:outline-none focus:border-hairline-strong focus:ring-2 focus:ring-ink/5 transition-all placeholder:text-muted"
              placeholder="Min. 8 characters" />
          </div>
          <p id="error-msg" class="hidden text-xs text-red-500"></p>
          <button type="submit" id="submit-btn"
            class="w-full h-10 text-sm font-medium text-canvas bg-ink rounded-lg hover:opacity-85 transition-opacity disabled:opacity-40">
            Create account
          </button>
        </form>
      </div>

      <p class="text-center text-sm text-muted mt-4">
        Already have an account? <a href="/login" class="text-ink font-medium hover:underline">Sign in</a>
      </p>
    </div>
  </main>
</Layout>

<script>
import { authClient } from '../lib/auth-client';

document.getElementById('google-btn')?.addEventListener('click', async () => {
  await authClient.signIn.social({ provider: 'google', callbackURL: '/account' });
});

document.getElementById('signup-form')?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const name     = (document.getElementById('name') as HTMLInputElement).value;
  const email    = (document.getElementById('email') as HTMLInputElement).value;
  const password = (document.getElementById('password') as HTMLInputElement).value;
  const btn      = document.getElementById('submit-btn') as HTMLButtonElement;
  btn.disabled   = true;
  btn.textContent = 'Creating account…';

  const { error } = await authClient.signUp.email({ name, email, password, callbackURL: '/account' });
  if (error) {
    btn.disabled    = false;
    btn.textContent = 'Create account';
    showError(error.message ?? `Sign up failed (${error.status ?? 'unknown error'})`);
  } else {
    window.location.href = '/account';
  }
});

function showError(msg: string) {
  const el = document.getElementById('error-msg')!;
  el.textContent = msg;
  el.classList.remove('hidden');
}
</script>
