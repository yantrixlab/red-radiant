---
const currentYear = new Date().getFullYear();

const tools = [
  { label: 'YouTube to MP3', href: '/' },
  { label: 'YouTube to WAV', href: '/youtube-to-wav' },
  { label: 'YouTube to M4A', href: '/youtube-to-m4a' },
  { label: 'Playlist Downloader', href: '/playlist-downloader' },
  { label: 'Shorts to MP3', href: '/shorts-to-mp3' },
];

const company = [
  { label: 'About', href: '/about' },
  { label: 'Privacy Policy', href: '/privacy' },
  { label: 'Terms of Service', href: '/terms' },
  { label: 'Contact', href: '/contact' },
  { label: 'DMCA', href: '/dmca' },
];

const resources = [
  { label: 'How it works', href: '#how-it-works' },
  { label: 'Supported formats', href: '#formats' },
  { label: 'FAQ', href: '#faq' },
  { label: 'Blog', href: '/blog' },
];
---

<footer class="bg-canvas border-t border-hairline">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <svg width="24" height="24" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="28" height="28" rx="7" fill="#171717"/>
            <path d="M9 7h6a3 3 0 0 1 3 3v2H9V7z" fill="white" opacity="0.9"/>
            <rect x="9" y="7" width="2" height="9" rx="1" fill="white"/>
            <circle cx="9" cy="17" r="2.5" fill="white"/>
            <path d="M13 19l2.5 2.5L18 19" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <line x1="15.5" y1="14" x2="15.5" y2="21.5" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span class="text-sm font-semibold text-ink">youtube2mp3file</span>
        </a>
        <p class="text-sm text-body leading-relaxed mb-4">
          The fastest, cleanest YouTube to audio converter. Free forever — no ads, no signup.
        </p>
        <p class="text-xs text-muted">
          Not affiliated with YouTube or Google.
        </p>
      </div>

      <!-- Tools -->
      <div>
        <p class="text-xs font-mono text-muted uppercase tracking-widest mb-4">Tools</p>
        <ul class="space-y-2.5">
          {tools.map(link => (
            <li>
              <a href={link.href} class="text-sm text-body hover:text-ink transition-colors duration-150">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <p class="text-xs font-mono text-muted uppercase tracking-widest mb-4">Company</p>
        <ul class="space-y-2.5">
          {company.map(link => (
            <li>
              <a href={link.href} class="text-sm text-body hover:text-ink transition-colors duration-150">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <p class="text-xs font-mono text-muted uppercase tracking-widest mb-4">Resources</p>
        <ul class="space-y-2.5">
          {resources.map(link => (
            <li>
              <a href={link.href} class="text-sm text-body hover:text-ink transition-colors duration-150">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <div class="mt-12 pt-6 border-t border-hairline flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-muted">
        &copy; {currentYear} youtube2mp3file.com — All rights reserved.
      </p>
      <p class="text-xs text-muted">
        Made with care for music lovers everywhere.
      </p>
    </div>
  </div>
</footer>
