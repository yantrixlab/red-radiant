---
import Converter from './Converter.astro';
---

<section class="relative min-h-[90vh] flex flex-col items-center justify-center pt-28 pb-20 overflow-hidden bg-canvas">

  <!-- Mesh gradient background (atmospheric, hero-scale only) -->
  <div
    class="pointer-events-none absolute inset-0"
    aria-hidden="true"
    style="
      background:
        radial-gradient(ellipse 90% 60% at 50% -10%, rgba(0,124,240,0.09) 0%, transparent 60%),
        radial-gradient(ellipse 60% 50% at 85% 30%, rgba(121,40,202,0.06) 0%, transparent 55%),
        radial-gradient(ellipse 50% 60% at 15% 70%, rgba(0,223,216,0.06) 0%, transparent 55%),
        radial-gradient(ellipse 40% 40% at 60% 80%, rgba(255,0,128,0.04) 0%, transparent 50%);
    "
  ></div>

  <!-- Grid texture overlay (subtle) -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.015]"
    aria-hidden="true"
    style="background-image: linear-gradient(#171717 1px, transparent 1px), linear-gradient(90deg, #171717 1px, transparent 1px); background-size: 40px 40px;"
  ></div>

  <div class="relative z-10 w-full max-w-6xl mx-auto px-6 flex flex-col items-center text-center">

    <!-- Eyebrow badge -->
    <div class="inline-flex items-center gap-2 bg-canvas-soft border border-hairline rounded-full px-3.5 py-1.5 mb-8 shadow-[0px_1px_1px_#00000005,inset_0_0_0_1px_#00000014]">
      <span class="w-1.5 h-1.5 rounded-full bg-success inline-block animate-pulse"></span>
      <span class="text-xs text-body font-medium">Free · No Ads · No Signup</span>
    </div>

    <!-- Headline -->
    <h1 class="text-5xl sm:text-6xl font-semibold text-ink leading-[1.05] tracking-[-0.05em] max-w-3xl mb-5">
      Convert YouTube to
      <span class="relative inline-block">
        <span class="relative z-10">MP3.</span>
        <span
          class="absolute inset-x-0 bottom-1 h-[6px] rounded-full opacity-30 pointer-events-none"
          style="background: linear-gradient(90deg, #007cf0, #7928ca, #ff0080);"
          aria-hidden="true"
        ></span>
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="text-lg text-body max-w-xl leading-relaxed mb-10">
      Paste any YouTube link — video, playlist, or Short.<br class="hidden sm:block" />
      Download as <strong class="text-ink font-medium">MP3</strong>, <strong class="text-ink font-medium">WAV</strong>, or <strong class="text-ink font-medium">M4A</strong> in seconds. Always free.
    </p>

    <!-- Converter tool -->
    <div class="w-full max-w-2xl">
      <Converter />
    </div>

    <!-- Trust stats -->
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mt-10">
      {[
        { stat: '10M+', label: 'downloads' },
        { stat: '320 kbps', label: 'max quality' },
        { stat: '0 ads', label: 'ever' },
        { stat: 'All devices', label: 'supported' },
      ].map(item => (
        <div class="flex items-center gap-2">
          <span class="text-sm font-semibold text-ink">{item.stat}</span>
          <span class="text-sm text-muted">{item.label}</span>
        </div>
      ))}
    </div>

  </div>

</section>
