---
import Converter from './Converter.astro';
---

<section class="relative min-h-[90vh] flex flex-col items-center justify-center pt-28 pb-20 overflow-hidden bg-[#0a0a0a]">

  <!-- YouTube red radial glow top-center -->
  <div
    class="pointer-events-none absolute inset-0"
    aria-hidden="true"
    style="
      background:
        radial-gradient(ellipse 80% 50% at 50% -5%, rgba(255,0,0,0.18) 0%, transparent 65%),
        radial-gradient(ellipse 50% 40% at 80% 60%, rgba(200,0,0,0.07) 0%, transparent 55%),
        radial-gradient(ellipse 40% 35% at 20% 70%, rgba(180,0,0,0.05) 0%, transparent 50%);
    "
  ></div>

  <!-- Subtle grid texture -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.04]"
    aria-hidden="true"
    style="background-image: linear-gradient(rgba(255,255,255,0.6) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.6) 1px, transparent 1px); background-size: 40px 40px;"
  ></div>

  <!-- Noise grain overlay -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.03]"
    aria-hidden="true"
    style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E'); background-size: 200px 200px;"
  ></div>

  <div class="relative z-10 w-full max-w-6xl mx-auto px-6 flex flex-col items-center text-center">

    <!-- Eyebrow badge -->
    <div class="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-full px-3.5 py-1.5 mb-8 backdrop-blur-sm">
      <span class="w-1.5 h-1.5 rounded-full bg-[#ff0000] inline-block animate-pulse shadow-[0_0_6px_rgba(255,0,0,0.8)]"></span>
      <span class="text-xs text-white/70 font-medium tracking-wide">Free · No Ads · No Signup</span>
    </div>

    <!-- Headline -->
    <h1 class="text-5xl sm:text-7xl font-bold text-white leading-[1.02] tracking-[-0.04em] max-w-4xl mb-5">
      Convert YouTube to
      <span class="relative inline-block">
        <span class="relative z-10 text-[#ff0000]">MP3.</span>
        <!-- red glow under text -->
        <span
          class="absolute inset-x-0 -bottom-1 h-[3px] rounded-full pointer-events-none"
          style="background: linear-gradient(90deg, transparent, #ff0000, transparent); filter: blur(4px); opacity: 0.8;"
          aria-hidden="true"
        ></span>
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="text-lg text-white/50 max-w-xl leading-relaxed mb-10">
      Paste any YouTube link — video, playlist, or Short.<br class="hidden sm:block" />
      Download as <strong class="text-white/80 font-medium">MP3</strong>, <strong class="text-white/80 font-medium">WAV</strong>, or <strong class="text-white/80 font-medium">M4A</strong> in seconds. Always free.
    </p>

    <!-- Converter tool -->
    <div class="w-full max-w-2xl">
      <Converter />
    </div>

    <!-- Trust stats -->
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mt-10">
      {[
        { stat: '10M+', label: 'downloads' },
        { stat: '320 kbps', label: 'max quality' },
        { stat: '0 ads', label: 'ever' },
        { stat: 'All devices', label: 'supported' },
      ].map(item => (
        <div class="flex items-center gap-2">
          <span class="text-sm font-semibold text-white">{item.stat}</span>
          <span class="text-sm text-white/40">{item.label}</span>
        </div>
      ))}
    </div>

  </div>

</section>
