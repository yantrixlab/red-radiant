---
const features = [
  {
    title: 'Multiple formats',
    description: 'Download as MP3, WAV, or M4A. Each format suits a different use case — from streaming to professional audio editing.',
    icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3 9h12M3 4.5h12M3 13.5h7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    badge: 'MP3 · WAV · M4A',
  },
  {
    title: '320 kbps HD quality',
    description: 'Extract audio at the highest possible MP3 bitrate. Hear every detail — ideal for music lovers and DJs.',
    icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 2v14M5 6v6M13 4v10M1 8v2M17 8v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    badge: 'Up to 320 kbps',
  },
  {
    title: 'Playlist support',
    description: 'Paste a full YouTube playlist URL and download all tracks at once, saved as individual files.',
    icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="2" y="3" width="14" height="3" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="2" y="8" width="10" height="3" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="2" y="13" width="7" height="2" rx="1" stroke="currentColor" stroke-width="1.5"/></svg>`,
    badge: 'Entire playlists',
  },
  {
    title: 'Zero ads, forever',
    description: 'No pop-ups, no banner ads, no redirects. We make money differently so your experience stays clean.',
    icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M5.5 9l2.5 2.5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    badge: 'Ad-free',
  },
  {
    title: 'No account needed',
    description: 'Paste, convert, download — that\'s it. We never ask for your email or create a profile.',
    icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="6.5" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M3 15.5c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M11.5 4l1.5 1.5L15 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    badge: 'No signup',
  },
  {
    title: 'Shorts & live support',
    description: 'Works with every YouTube URL format — standard videos, Shorts, live-stream archives, and youtu.be links.',
    icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="4" y="2" width="10" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M7 9l4-2-4-2v4z" fill="currentColor"/></svg>`,
    badge: 'All URL types',
  },
];
---

<section id="features" class="py-24 bg-canvas-soft border-t border-hairline">
  <div class="max-w-6xl mx-auto px-6">

    <div class="text-center mb-16">
      <p class="text-xs font-mono text-muted uppercase tracking-widest mb-3">Why choose us</p>
      <h2 class="text-3xl font-semibold text-ink tracking-tight">Built for people who just want the audio.</h2>
      <p class="text-base text-body mt-3 max-w-md mx-auto">No nonsense, no bloat. The fastest path from YouTube link to audio file.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {features.map((f) => (
        <div class="bg-canvas rounded-xl p-6 border border-hairline shadow-[0px_1px_1px_#00000005,0px_2px_2px_#0000000a,inset_0_0_0_1px_#00000014] group hover:shadow-[0px_2px_2px_#0000000a,0px_8px_8px_-8px_#0000000a,inset_0_0_0_1px_#00000014] transition-shadow duration-200">
          <div class="flex items-start justify-between mb-4">
            <div class="w-9 h-9 rounded-lg bg-canvas-soft-2 border border-hairline flex items-center justify-center text-ink">
              <Fragment set:html={f.icon} />
            </div>
            <span class="text-xs text-muted bg-canvas-soft-2 border border-hairline rounded-full px-2.5 py-0.5 font-mono">
              {f.badge}
            </span>
          </div>
          <h3 class="text-sm font-semibold text-ink mb-1.5">{f.title}</h3>
          <p class="text-sm text-body leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>
